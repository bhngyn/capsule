#!/usr/bin/env bash
# مُشغِّل كبسولة (macOS، بناء من المصدر) — يولِّده scripts/build-dist.sh.
#
# انقر مزدوجًا لبناء كبسولة من المصدر في المرة الأولى، ثم انقر مزدوجًا مرة
# أخرى لتشغيلها. مناسب للمحقّقين الذين يفضّلون البرامج المبنيّة محليًا
# والقابلة للتدقيق (تتم العملية بأكملها على هذا الماك بدون صورة جاهزة).
#
# ملاحظة: في المرة الأولى يجري تنزيل ما يقارب ٤٥٠ ميغابايت من الاعتماديات
# (حزم Debian، حزم PyPI، Chromium، خط Noto Sans JP). كل تشغيل بعد ذلك
# يكون فوريًا لأن Docker يحتفظ بالصورة في ذاكرته المؤقتة.
set -e

CONTAINER="capsule"
PORT=8080
DOWNLOADS="$HOME/Documents/Capsule"
CONFIG="$HOME/Documents/Capsule/.config"

cd "$(dirname "$0")"

echo "==============================================="
echo "  كبسولة — وثّق الويب بالدليل"
echo "  بناء من المصدر (يُجمَّع على هذا الماك)"
echo "==============================================="
echo

# ---------------------------------------------------------------------------
# ١. الكشف عن بنية المعالج (Apple Silicon أم Intel).
# ---------------------------------------------------------------------------
HOST_ARCH="$(uname -m)"
case "$HOST_ARCH" in
  arm64|aarch64) HOST_ARCH=arm64 ;;
  x86_64|amd64)  HOST_ARCH=amd64 ;;
  *)
    echo "بنية المعالج غير مدعومة: $HOST_ARCH"
    echo "كبسولة تدعم arm64 (Apple Silicon) و amd64 (Intel) فقط."
    read -n 1 -s -r -p "اضغط أي مفتاح للإغلاق..."; echo; exit 1
    ;;
esac
IMAGE_TAG="capsule:source-${HOST_ARCH}"

# ---------------------------------------------------------------------------
# ٢. مجلد المصدر يجب أن يكون موجودًا (يجب فك ضغط الـ zip كاملًا).
# ---------------------------------------------------------------------------
if [ ! -d "source" ] || [ ! -f "source/Dockerfile" ]; then
  echo "مجلد 'source/' مفقود بجانب هذا المُشغِّل."
  echo
  echo "تأكّد من أنك فككت ضغط ملف Capsule-source.zip بالكامل،"
  echo "وليس فقط هذا الملف. الترتيب الصحيح للمجلد:"
  echo
  echo "  Capsule-source/"
  echo "    Capsule-عربي.command   <- هذا الملف"
  echo "    source/"
  echo "      Dockerfile"
  echo "      app/"
  echo "      ..."
  read -n 1 -s -r -p "اضغط أي مفتاح للإغلاق..."; echo; exit 1
fi

# ---------------------------------------------------------------------------
# ٣. التحقّق من وجود Docker.
# ---------------------------------------------------------------------------
if ! command -v docker >/dev/null 2>&1; then
  cat <<'MSG'
Docker غير مثبَّت.

كبسولة تحتاج إلى Docker Desktop وهو مجاني.
رابط التنزيل:  https://www.docker.com/products/docker-desktop

بعد تثبيت Docker Desktop، انقر مزدوجًا على هذا المُشغِّل مرة أخرى.
MSG
  read -n 1 -s -r -p "اضغط أي مفتاح للإغلاق..."; echo; exit 1
fi

if ! docker info >/dev/null 2>&1; then
  echo "جاري تشغيل Docker Desktop... (التشغيل الأول قد يستغرق ٣٠ ثانية)"
  open -a Docker || true
  for _ in $(seq 1 60); do
    sleep 2
    if docker info >/dev/null 2>&1; then
      break
    fi
    printf "."
  done
  echo
  if ! docker info >/dev/null 2>&1; then
    echo "Docker Desktop لم يبدأ. افتحه من مجلد التطبيقات، ثم أعِد تشغيل هذا المُشغِّل."
    read -n 1 -s -r -p "اضغط أي مفتاح للإغلاق..."; echo; exit 1
  fi
fi

# ---------------------------------------------------------------------------
# ٤. بناء الصورة إن لم تكن موجودة.
#    يحتفظ BuildKit بالخطوات الناجحة، لذا أي إعادة تشغيل بعد فشل في الشبكة
#    تُكمل من حيث توقّفت ولا تُعيد التنزيل من الصفر.
# ---------------------------------------------------------------------------
if ! docker image inspect "$IMAGE_TAG" >/dev/null 2>&1; then
  cat <<MSG

------------------------------------------------------------
  بناء كبسولة من المصدر (لمرة واحدة فقط)
------------------------------------------------------------
هذه الخطوة تُجمِّع صورة Docker لمعمارية ${HOST_ARCH} على هذا الماك.
ستُنزَّل تقريبًا:

  ~ ٧٠ ميغابايت من حزم نظام Debian   (ffmpeg، خطوط، مكتبات Chromium)
  ~ ٩٠ ميغابايت من حزم Python       (FastAPI، Playwright، WeasyPrint، yt-dlp …)
  ~٣٠٠ ميغابايت من Chromium المُجرَّد (Playwright)
  ~  ٥ ميغابايت من خط Noto Sans JP

الإجمالي: حوالي ٤٥٠ ميغابايت من الشبكة، ونحو ١٫٧ غيغابايت على القرص بعد الانتهاء.

الزمن على اتصال إنترنت عادي:        ٨ إلى ١٥ دقيقة.
الزمن على اتصال بطيء أو محدود:   ٣٠ إلى ٦٠ دقيقة.

يمكنك ترك هذه النافذة تعمل والعودة إليها لاحقًا.

ستظهر مخرجات Docker لكلّ خطوة في الأسفل، وهذا طبيعي. كبسولة لا تُجري
أي اتصال شبكي خاص بها أثناء البناء؛ كلّ ما يجري تنزيله يأتي من Debian
ومن PyPI ومن شبكة Playwright، ويجلبه Docker بالنيابة عنك.
------------------------------------------------------------

MSG

  start_ts=$(date +%s)
  echo "بدأ البناء في: $(date '+%Y-%m-%d %H:%M:%S %Z')"
  echo "وسم الصورة:    $IMAGE_TAG"
  echo "مجلد البناء:   $(pwd)/source"
  echo

  if ! DOCKER_BUILDKIT=1 docker build \
        --platform "linux/${HOST_ARCH}" \
        --progress=plain \
        -t "$IMAGE_TAG" \
        ./source; then
    echo
    echo "------------------------------------------------------------"
    echo "  فشل البناء."
    echo "------------------------------------------------------------"
    echo "معظم حالات الفشل سببها الشبكة. للمتابعة:"
    echo
    echo "  ١. انقر مزدوجًا على هذا المُشغِّل مرة أخرى. يحتفظ Docker بكلّ"
    echo "     الخطوات الناجحة في ذاكرته المؤقتة، ولن تُعاد إلا الخطوات"
    echo "     التي لم تكتمل."
    echo
    echo "  ٢. تأكّد أن Docker Desktop لا يزال يعمل (أيقونة الحوت في"
    echo "     شريط القائمة). إن كان يُعاد تشغيله، انتظر حتى ينتهي ثم"
    echo "     أعِد المحاولة."
    echo
    echo "  ٣. إن كنت على شبكة محجوبة (فندق أو مطار أو مقهى)، افتح"
    echo "     المتصفح وسجّل دخولك إلى الشبكة، ثم أعِد تشغيل المُشغِّل."
    echo
    echo "  ٤. إن استمرّت نفس الخطوة في الفشل، انسخ آخر ٣٠ سطرًا من"
    echo "     المخرجات أعلاه وأرسلها في تقرير العطل."
    read -n 1 -s -r -p "اضغط أي مفتاح للإغلاق..."; echo; exit 1
  fi

  end_ts=$(date +%s)
  elapsed=$((end_ts - start_ts))
  mins=$((elapsed / 60))
  secs=$((elapsed % 60))
  echo
  echo "------------------------------------------------------------"
  printf "  اكتمل البناء خلال %d دقيقة و%02d ثانية. جارٍ تشغيل كبسولة...\n" "$mins" "$secs"
  echo "------------------------------------------------------------"
  echo
fi

# ---------------------------------------------------------------------------
# ٥. تشغيل الحاوية باستخدام الوسم الخاص بهذه البنية. نفس منطق المُشغِّل
#    الجاهز: نكتشف فقدان ربط المنفذ ونعيد إنشاء الحاوية إن لزم.
# ---------------------------------------------------------------------------
mkdir -p "$DOWNLOADS" "$CONFIG"

start_fresh() {
  docker run -d \
    --name "$CONTAINER" \
    --restart no \
    -p "${PORT}:8080" \
    -v "$DOWNLOADS:/downloads" \
    -v "$CONFIG:/config" \
    -e "CAPSULE_HOST_DOWNLOADS_DIR=$DOWNLOADS" \
    "$IMAGE_TAG" >/dev/null
}

port_is_bound() {
  docker port "$CONTAINER" "${PORT}/tcp" >/dev/null 2>&1
}

if docker ps -a --format '{{.Names}}' | grep -qx "$CONTAINER"; then
  if ! docker ps --format '{{.Names}}' | grep -qx "$CONTAINER"; then
    docker start "$CONTAINER" >/dev/null
  fi
  if port_is_bound; then
    echo "كبسولة تعمل مسبقًا."
  else
    echo "جارٍ إصلاح ربط الشبكة لكبسولة..."
    docker rm -f "$CONTAINER" >/dev/null
    start_fresh
    echo "تم تشغيل كبسولة."
  fi
else
  start_fresh
  echo "تم تشغيل كبسولة."
fi

# ---------------------------------------------------------------------------
# ٦. الانتظار حتى يستجيب التطبيق ثم فتح المتصفح.
# ---------------------------------------------------------------------------
URL="http://localhost:${PORT}"
echo "في انتظار التطبيق ليصبح جاهزًا..."
for _ in $(seq 1 30); do
  if curl -sf "$URL/healthz" >/dev/null 2>&1; then
    open "$URL"
    echo
    echo "كبسولة مفتوحة في متصفحك على العنوان  $URL"
    echo "لإيقاف التطبيق:                docker stop capsule"
    echo "لتشغيله في المرة القادمة:    انقر مزدوجًا على هذا المُشغِّل."
    echo "كبسولة لا تعمل تلقائيًا عند إقلاع جهازك."
    sleep 2
    exit 0
  fi
  sleep 1
done

echo "لم يستجب التطبيق على $URL."
echo "إن تكرّر هذا، شغِّل:  docker rm -f capsule"
echo "...ثم انقر مزدوجًا على هذا المُشغِّل مرة أخرى."
read -n 1 -s -r -p "اضغط أي مفتاح للإغلاق..."; echo; exit 1
