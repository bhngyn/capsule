#!/usr/bin/env bash
# Capsule launcher (macOS) — generated by scripts/build-dist.sh.
# Double-click to install on first run, double-click again to start.
#
# This launcher loads a pre-built Capsule Docker image from the bundle
# directory next to it (images/capsule-image-{arch}.tar). No network
# calls are made to pull or update the image. The bundled image digest
# is verified on every launch so a stale or wrong-arch image is replaced
# automatically.
set -e

# Placeholders substituted by scripts/build-dist.sh at build time.
# For the universal launcher these are left empty and resolved at runtime.
EXPECTED_ARCH="@ARCH@"
IMAGE_TAG="@IMAGE_TAG@"
TAR_NAME="@TAR_NAME@"
EXPECTED_DIGEST="@EXPECTED_DIGEST@"

CONTAINER="capsule"
PORT=8080
DOWNLOADS="$HOME/Documents/Capsule"
CONFIG="$HOME/Documents/Capsule/.config"

cd "$(dirname "$0")"

echo "============================================="
echo "  Capsule -- Capture the web, with proof"
echo "============================================="
echo

# ---------------------------------------------------------------------------
# 1. Detect host architecture.
# ---------------------------------------------------------------------------
HOST_ARCH="$(uname -m)"
case "$HOST_ARCH" in
  arm64|aarch64) HOST_ARCH=arm64 ;;
  x86_64|amd64)  HOST_ARCH=amd64 ;;
  *)
    echo "Unsupported CPU architecture: $HOST_ARCH"
    echo "Capsule supports arm64 (Apple Silicon) and amd64 (Intel)."
    read -n 1 -s -r -p "Press any key to close..."; echo; exit 1
    ;;
esac

# ---------------------------------------------------------------------------
# 2. Universal launcher — resolve per-arch placeholders at runtime.
#    When @ARCH@ was left empty by the build script, EXPECTED_ARCH is
#    empty at this point; fall into the runtime-resolution branch.
# ---------------------------------------------------------------------------
if [ -z "$EXPECTED_ARCH" ]; then
  EXPECTED_ARCH="$HOST_ARCH"
  IMAGE_TAG="capsule:$HOST_ARCH"
  TAR_NAME="capsule-image-$HOST_ARCH.tar"
  DIGEST_FILE="images/capsule-image-$HOST_ARCH.digest"
  if [ -f "$DIGEST_FILE" ]; then
    EXPECTED_DIGEST="$(cat "$DIGEST_FILE")"
  fi
fi

# ---------------------------------------------------------------------------
# 3. OS-specific launcher: refuse if the user grabbed the wrong distribution.
# ---------------------------------------------------------------------------
if [ "$HOST_ARCH" != "$EXPECTED_ARCH" ]; then
  echo "Wrong distribution: this is the $EXPECTED_ARCH build of Capsule"
  echo "but your Mac is $HOST_ARCH."
  echo
  echo "Download the $HOST_ARCH distribution instead:"
  if [ "$HOST_ARCH" = "arm64" ]; then
    echo "  Capsule-mac-applesilicon.zip"
  else
    echo "  Capsule-mac-intel.zip"
  fi
  read -n 1 -s -r -p "Press any key to close..."; echo; exit 1
fi

# ---------------------------------------------------------------------------
# 4. Docker availability checks (preserve existing UX).
# ---------------------------------------------------------------------------
if ! command -v docker >/dev/null 2>&1; then
  cat <<'MSG'
Docker is not installed.

Capsule needs Docker Desktop. It is free.
Download:  https://www.docker.com/products/docker-desktop

After installing Docker Desktop, double-click this launcher again.
MSG
  read -n 1 -s -r -p "Press any key to close..."; echo; exit 1
fi

if ! docker info >/dev/null 2>&1; then
  echo "Starting Docker Desktop... (first launch can take 30 seconds)"
  open -a Docker || true
  for _ in $(seq 1 60); do
    sleep 2
    if docker info >/dev/null 2>&1; then
      break
    fi
    printf "."
  done
  echo
  if ! docker info >/dev/null 2>&1; then
    echo "Docker Desktop did not start. Open it from Applications, then re-run this launcher."
    read -n 1 -s -r -p "Press any key to close..."; echo; exit 1
  fi
fi

# ---------------------------------------------------------------------------
# 5. Force-reload the per-arch image if it is missing or its digest is stale.
#    This is the fix for the AMD64 warning chip: a wrong-arch image with the
#    right tag is detected by comparing the loaded image ID against the digest
#    embedded at build time.
# ---------------------------------------------------------------------------
needs_load=1
if loaded_id="$(docker image inspect "$IMAGE_TAG" --format '{{.Id}}' 2>/dev/null)"; then
  if [ -n "$EXPECTED_DIGEST" ] && [ "$loaded_id" = "$EXPECTED_DIGEST" ]; then
    needs_load=0
  fi
fi

if [ "$needs_load" = 1 ]; then
  if [ ! -f "images/$TAR_NAME" ]; then
    echo "Capsule image bundle missing: images/$TAR_NAME"
    echo "This launcher must live next to the 'images/' folder from the Capsule distribution package."
    read -n 1 -s -r -p "Press any key to close..."; echo; exit 1
  fi
  # Remove any existing image with this tag (possibly the wrong arch).
  docker rmi -f "$IMAGE_TAG" 2>/dev/null || true
  echo "Loading Capsule image (this takes about a minute on first launch)..."
  # The image tar is gzip-compressed in the bundle (build-dist.sh) so the
  # download stays small. Decompress on the fly into docker load — no temp
  # file, and macOS ships gunzip natively so no extra dependency.
  if ! gunzip -c "images/$TAR_NAME" | docker load; then
    echo "Could not load the Capsule image from images/$TAR_NAME."
    echo "The file may be corrupted; download the distribution package again."
    read -n 1 -s -r -p "Press any key to close..."; echo; exit 1
  fi
fi

# ---------------------------------------------------------------------------
# 6. Start or resume the container using the explicit per-arch tag.
#    Never capsule:latest — using the per-arch tag ensures two side-by-side
#    installations (arm64 + amd64) can coexist without shadowing each other.
#
#    A long-running container can end up with no actual host-port binding
#    even though Docker says it is "Up": Docker Desktop's port-forward layer
#    sometimes drops the binding silently after a sleep/wake cycle or a
#    daemon restart. From then on, http://localhost:8080 is unreachable
#    until the container is recreated. We detect that here with `docker
#    port` and self-heal by recreating the container.
# ---------------------------------------------------------------------------
mkdir -p "$DOWNLOADS" "$CONFIG"

start_fresh() {
  # Capture stderr so common failures translate to investigator-friendly
  # text (CLAUDE.md §16 v0.11 bucket 1 #2). On success, the container id
  # goes to /dev/null. Exit 0 → caller continues; exit 1 → caller already
  # printed the translated message and we leave the launcher to exit.
  local err_tmp
  err_tmp="$(mktemp -t capsule-launcher.XXXXXX)"
  if docker run -d \
        --name "$CONTAINER" \
        --restart no \
        -p "${PORT}:8080" \
        -v "$DOWNLOADS:/downloads" \
        -v "$CONFIG:/config" \
        -e "CAPSULE_HOST_DOWNLOADS_DIR=$DOWNLOADS" \
        "$IMAGE_TAG" >/dev/null 2>"$err_tmp"
  then
    rm -f "$err_tmp"
    return 0
  fi
  local err
  err="$(cat "$err_tmp")"
  rm -f "$err_tmp"
  case "$err" in
    *"address already in use"*|*"port is already allocated"*)
      cat <<MSG
Port ${PORT} on your computer is already taken by another app.

Two common causes:
  - A previous Capsule container is still running. Stop it with:
      docker rm -f $CONTAINER
  - Another local web app is bound to ${PORT}. Use a different port:
      edit this launcher and change "-p ${PORT}:8080" to "-p 9090:8080",
      then open http://localhost:9090 instead.

Docker's exact message:
$err
MSG
      ;;
    *"permission denied"*)
      cat <<MSG
macOS denied access to one of the folders this launcher tried to mount.

Open System Settings -> Privacy & Security -> Files and Folders and
make sure Docker has access to your Documents folder. Then re-run this
launcher.

Docker's exact message:
$err
MSG
      ;;
    *"Cannot connect to the Docker daemon"*|*"daemon socket"*)
      cat <<MSG
Lost the connection to Docker Desktop mid-launch. Open Docker Desktop,
wait until the whale icon settles, then re-run this launcher.

Docker's exact message:
$err
MSG
      ;;
    *)
      echo "Capsule could not start. Docker's message:"
      echo "$err"
      ;;
  esac
  read -n 1 -s -r -p "Press any key to close..."; echo
  exit 1
}

# 0 iff the named container has a host-port binding for $PORT/tcp.
port_is_bound() {
  docker port "$CONTAINER" "${PORT}/tcp" >/dev/null 2>&1
}

if docker ps -a --format '{{.Names}}' | grep -qx "$CONTAINER"; then
  if ! docker ps --format '{{.Names}}' | grep -qx "$CONTAINER"; then
    docker start "$CONTAINER" >/dev/null
  fi
  if port_is_bound; then
    echo "Capsule is already running."
  else
    echo "Repairing Capsule's network binding..."
    docker rm -f "$CONTAINER" >/dev/null
    start_fresh
    echo "Capsule started."
  fi
else
  start_fresh
  echo "Capsule started."
fi

# ---------------------------------------------------------------------------
# 7. Wait for the app and open the browser.
# ---------------------------------------------------------------------------
URL="http://localhost:${PORT}"
echo "Waiting for the app to come online..."
for _ in $(seq 1 30); do
  if curl -sf "$URL/healthz" >/dev/null 2>&1; then
    open "$URL"
    echo
    echo "Capsule is open in your browser at  $URL"
    echo "To stop the app:           docker stop capsule"
    echo "To start it next time:     double-click this launcher."
    echo "Capsule does NOT auto-start with your computer."
    sleep 2
    exit 0
  fi
  sleep 1
done

echo "App did not respond at $URL."
echo "If this keeps happening, run:  docker rm -f capsule"
echo "...then double-click this launcher again."
read -n 1 -s -r -p "Press any key to close..."; echo; exit 1
