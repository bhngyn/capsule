#!/usr/bin/env bash
# Capsule launcher (macOS, source build) — generated by scripts/build-dist.sh.
#
# Double-click to build Capsule from source the first time, double-click again
# to start it. Best for investigators who prefer auditable, locally-built
# software (the entire build runs on this Mac with no pre-baked image).
#
# Trade-off: the first run downloads ~450 MB of upstream dependencies
# (Debian apt packages, PyPI wheels, Chromium headless-shell, Noto Sans JP).
# Subsequent launches are instant because Docker caches the built image.
#
# Slow-connection design:
#   - Up-front estimates (size + time) so the user knows what to expect.
#   - --progress=plain streams every build step verbatim, with timestamps.
#   - On failure, instructions are plain-language and cache-aware (re-running
#     only re-fetches steps that did not complete).
set -e

CONTAINER="capsule"
PORT=8080
DOWNLOADS="$HOME/Documents/Capsule"
CONFIG="$HOME/Documents/Capsule/.config"

cd "$(dirname "$0")"

echo "==============================================="
echo "  Capsule -- Capture the web, with proof"
echo "  Source build (compiled on this Mac)"
echo "==============================================="
echo

# ---------------------------------------------------------------------------
# 1. Detect host architecture (Apple Silicon vs Intel).
# ---------------------------------------------------------------------------
HOST_ARCH="$(uname -m)"
case "$HOST_ARCH" in
  arm64|aarch64) HOST_ARCH=arm64 ;;
  x86_64|amd64)  HOST_ARCH=amd64 ;;
  *)
    echo "Unsupported CPU architecture: $HOST_ARCH"
    echo "Capsule supports arm64 (Apple Silicon) and amd64 (Intel)."
    read -n 1 -s -r -p "Press any key to close..."; echo; exit 1
    ;;
esac
IMAGE_TAG="capsule:source-${HOST_ARCH}"

# ---------------------------------------------------------------------------
# 2. Source folder must be present (must extract the whole zip, not just this file).
# ---------------------------------------------------------------------------
if [ ! -d "source" ] || [ ! -f "source/Dockerfile" ]; then
  echo "The 'source/' folder is missing next to this launcher."
  echo
  echo "Make sure you extracted the entire Capsule-source.zip,"
  echo "not just this Capsule.command file. The folder layout should be:"
  echo
  echo "  Capsule-source/"
  echo "    Capsule.command   <- this file"
  echo "    source/"
  echo "      Dockerfile"
  echo "      app/"
  echo "      ..."
  read -n 1 -s -r -p "Press any key to close..."; echo; exit 1
fi

# ---------------------------------------------------------------------------
# 3. Docker availability checks.
# ---------------------------------------------------------------------------
if ! command -v docker >/dev/null 2>&1; then
  cat <<'MSG'
Docker is not installed.

Capsule needs Docker Desktop. It is free.
Download:  https://www.docker.com/products/docker-desktop

After installing Docker Desktop, double-click this launcher again.
MSG
  read -n 1 -s -r -p "Press any key to close..."; echo; exit 1
fi

if ! docker info >/dev/null 2>&1; then
  echo "Starting Docker Desktop... (first launch can take 30 seconds)"
  open -a Docker || true
  for _ in $(seq 1 60); do
    sleep 2
    if docker info >/dev/null 2>&1; then
      break
    fi
    printf "."
  done
  echo
  if ! docker info >/dev/null 2>&1; then
    echo "Docker Desktop did not start. Open it from Applications, then re-run this launcher."
    read -n 1 -s -r -p "Press any key to close..."; echo; exit 1
  fi
fi

# ---------------------------------------------------------------------------
# 4. Build the image if it does not already exist.
#    BuildKit caches every step, so a re-run after a network failure only
#    re-fetches the steps that did not complete.
# ---------------------------------------------------------------------------
if ! docker image inspect "$IMAGE_TAG" >/dev/null 2>&1; then
  cat <<MSG

------------------------------------------------------------
  Building Capsule from source (one-time)
------------------------------------------------------------
This step compiles a Docker image for ${HOST_ARCH} on this Mac.
The build pulls roughly:

  ~ 70 MB of Debian system packages   (ffmpeg, fonts, Chromium libs)
  ~ 90 MB of Python wheels            (FastAPI, Playwright, WeasyPrint, yt-dlp...)
  ~300 MB of Chromium headless-shell  (Playwright)
  ~  5 MB of Noto Sans JP font subset

Total: about 450 MB over the network. About 1.7 GB on disk when done.

Time on a typical broadband connection:  8 - 15 minutes.
Time on a slow or metered connection:   30 - 60 minutes.

You can leave this window open and check back later.

The full per-step build output appears below. That is expected — Capsule
makes no network calls of its own during the build; every download you
see comes from Debian, PyPI, or the Playwright CDN, fetched by Docker
on your behalf.
------------------------------------------------------------

MSG

  start_ts=$(date +%s)
  echo "Build started at: $(date '+%Y-%m-%d %H:%M:%S %Z')"
  echo "Image tag:        $IMAGE_TAG"
  echo "Build context:    $(pwd)/source"
  echo

  # --progress=plain keeps step output streaming when not on an interactive
  # TTY (e.g. when launched from Finder, where stdout goes to Terminal.app
  # but BuildKit's TUI mode misbehaves).
  if ! DOCKER_BUILDKIT=1 docker build \
        --platform "linux/${HOST_ARCH}" \
        --progress=plain \
        -t "$IMAGE_TAG" \
        ./source; then
    echo
    echo "------------------------------------------------------------"
    echo "  Build failed."
    echo "------------------------------------------------------------"
    echo "Most build failures are network-related. To recover:"
    echo
    echo "  1. Double-click this launcher again. Docker keeps every"
    echo "     successful step cached, so only the steps that did not"
    echo "     complete will be re-fetched."
    echo
    echo "  2. Check that Docker Desktop is still running (whale icon"
    echo "     in the menu bar). If it is restarting, wait for it to"
    echo "     finish before re-running."
    echo
    echo "  3. If you are on a captive network (hotel / airport / cafe),"
    echo "     open a browser and complete the network sign-in, then"
    echo "     re-run this launcher."
    echo
    echo "  4. If the same step fails repeatedly, copy the last 30 lines"
    echo "     of output above into a bug report."
    read -n 1 -s -r -p "Press any key to close..."; echo; exit 1
  fi

  end_ts=$(date +%s)
  elapsed=$((end_ts - start_ts))
  mins=$((elapsed / 60))
  secs=$((elapsed % 60))
  echo
  echo "------------------------------------------------------------"
  printf "  Build complete in %dm %02ds. Starting Capsule...\n" "$mins" "$secs"
  echo "------------------------------------------------------------"
  echo
fi

# ---------------------------------------------------------------------------
# 5. Start or resume the container using the explicit per-arch source tag.
#    Same self-healing logic as the prebuilt launcher: detect a missing
#    host-port binding and recreate the container if needed.
# ---------------------------------------------------------------------------
mkdir -p "$DOWNLOADS" "$CONFIG"

start_fresh() {
  docker run -d \
    --name "$CONTAINER" \
    --restart no \
    -p "${PORT}:8080" \
    -v "$DOWNLOADS:/downloads" \
    -v "$CONFIG:/config" \
    -e "CAPSULE_HOST_DOWNLOADS_DIR=$DOWNLOADS" \
    "$IMAGE_TAG" >/dev/null
}

port_is_bound() {
  docker port "$CONTAINER" "${PORT}/tcp" >/dev/null 2>&1
}

if docker ps -a --format '{{.Names}}' | grep -qx "$CONTAINER"; then
  if ! docker ps --format '{{.Names}}' | grep -qx "$CONTAINER"; then
    docker start "$CONTAINER" >/dev/null
  fi
  if port_is_bound; then
    echo "Capsule is already running."
  else
    echo "Repairing Capsule's network binding..."
    docker rm -f "$CONTAINER" >/dev/null
    start_fresh
    echo "Capsule started."
  fi
else
  start_fresh
  echo "Capsule started."
fi

# ---------------------------------------------------------------------------
# 6. Wait for the app and open the browser.
# ---------------------------------------------------------------------------
URL="http://localhost:${PORT}"
echo "Waiting for the app to come online..."
for _ in $(seq 1 30); do
  if curl -sf "$URL/healthz" >/dev/null 2>&1; then
    open "$URL"
    echo
    echo "Capsule is open in your browser at  $URL"
    echo "To stop the app:           docker stop capsule"
    echo "To start it next time:     double-click this launcher."
    echo "Capsule does NOT auto-start with your computer."
    sleep 2
    exit 0
  fi
  sleep 1
done

echo "App did not respond at $URL."
echo "If this keeps happening, run:  docker rm -f capsule"
echo "...then double-click this launcher again."
read -n 1 -s -r -p "Press any key to close..."; echo; exit 1
