{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://capsule.example/schemas/meta.schema.json",
  "title": "Capsule capture metadata (meta.json)",
  "description": "Per-capture forensic record. Source of truth for the integrity story; signed by the case keypair. Schema v2 (hardening pass) adds tab_context, capture-side mutations (blocking + banner hide), render-wait outcomes, and cookie-set provenance hash. Schema v3 (Track A) adds the per-item manifest PDF artifact role + checksum, plus capture.report_lang for the locale the manifest PDF was rendered in.",
  "type": "object",
  "required": [
    "schema_version",
    "job_uuid",
    "capture_kind",
    "case",
    "url_submitted",
    "url_final",
    "url_redirect_chain",
    "platform",
    "title",
    "title_original",
    "capture_date",
    "artifacts",
    "checksums",
    "tools",
    "signing_key_fp"
  ],
  "properties": {
    "schema_version": { "enum": [1, 2, 3] },
    "job_uuid": { "type": "string" },
    "capture_kind": { "enum": ["media", "page_only"] },
    "case": {
      "type": "object",
      "required": ["id", "slug", "name"],
      "properties": {
        "id": { "type": "integer" },
        "slug": { "type": "string" },
        "name": { "type": "string" }
      }
    },
    "url_submitted": { "type": "string" },
    "url_final": { "type": "string" },
    "url_redirect_chain": { "type": "array", "items": { "type": "string" } },
    "platform": { "type": "string" },
    "video_id": { "type": ["string", "null"] },
    "uploader": { "type": ["string", "null"] },
    "uploader_original": { "type": ["string", "null"] },
    "title": { "type": "string" },
    "title_original": { "type": "string" },
    "description_original": { "type": ["string", "null"] },
    "upload_date": { "type": ["string", "null"] },
    "capture_date": { "type": "string", "description": "ISO 8601 UTC" },
    "duration_seconds": { "type": ["integer", "null"] },
    "format_details": { "type": ["object", "null"] },
    "response_headers": { "type": ["object", "null"] },
    "authenticated_domains": { "type": "array", "items": { "type": "string" } },
    "artifacts": {
      "type": "object",
      "description": "Artifact role → relative path under /downloads. Roles include page_mhtml, page_screenshot, page_warc, user_browser_*, plus tab_context / session_state / dom_snapshot_* (v2). v3 adds ``manifest_pdf`` — the per-item evidence manifest PDF; its hash is bound to meta.json via the signature.",
      "additionalProperties": { "type": "string" }
    },
    "checksums": {
      "type": "object",
      "description": "Artifact role → { md5, sha256, size_bytes }.",
      "additionalProperties": {
        "type": "object",
        "required": ["md5", "sha256", "size_bytes"],
        "properties": {
          "md5": { "type": "string" },
          "sha256": { "type": "string" },
          "size_bytes": { "type": "integer" }
        }
      }
    },
    "tools": {
      "type": "object",
      "required": ["app_version", "ytdlp_version", "chromium_version", "browsertrix_version"],
      "properties": {
        "app_version": { "type": "string" },
        "ytdlp_version": { "type": "string" },
        "chromium_version": { "type": "string" },
        "browsertrix_version": { "type": "string" }
      }
    },
    "capture": {
      "type": "object",
      "description": "Capture-side mutations and render-wait outcomes (schema v2). Every blocked request and every banner CSS-hide is recorded here; the underlying WARC still contains the request attempts as aborted, so forensic completeness is preserved.",
      "properties": {
        "render_waits": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "ok", "elapsed_ms", "timed_out"],
            "properties": {
              "name": { "type": "string" },
              "ok": { "type": "boolean" },
              "elapsed_ms": { "type": "integer" },
              "timed_out": { "type": "boolean" },
              "detail": { "type": ["string", "null"] }
            }
          }
        },
        "blocked_request_count": { "type": "integer" },
        "blocked_requests_sample": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Up to 200 URLs of blocked requests. Full list is in the WARC."
        },
        "blocklist_version": { "type": ["string", "null"] },
        "banner_hide_applied": { "type": "boolean" },
        "banner_hide_version": { "type": ["string", "null"] },
        "tab_context_used": { "type": "boolean" },
        "report_lang": {
          "type": "string",
          "description": "UI locale active at submission time. The per-item manifest PDF was rendered in this locale (RTL/LTR direction, label set, font fallbacks). v3."
        }
      }
    },
    "cookies_snapshot_sha256": {
      "type": ["string", "null"],
      "description": "SHA-256 of the cookies file the job consumed. Binds the capture to the exact cookie set without ever logging values. v2."
    },
    "ephemeral_cookies_used": {
      "type": "boolean",
      "description": "True iff the job used a one-shot ephemeral cookie file (extension-supplied, never persisted to the case directory). v2."
    },
    "audit_log_entry_id": { "type": ["integer", "null"] },
    "signing_key_fp": { "type": "string" }
  }
}
